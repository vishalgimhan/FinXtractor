# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- LLM provider credentials ---
# Required when the chat/VLM tiers run against OpenRouter (the default).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# --- Optional: per-run backend overrides ---
# Override the `active` provider in config/models.yaml without editing files.
# Leave unset to use the config defaults (OpenRouter; Docling; PyMuPDF).
# FINX_LLM_PROVIDER=ollama       # chat LLM:        ollama | openrouter
# FINX_VLM_PROVIDER=ollama       # vision LLM:      ollama | openrouter
# FINX_TABLE_BACKEND=docling     # table extractor: docling
# FINX_PDF_READER=pymupdf        # PDF reader:      pymupdf

# When running fully offline against Ollama in Docker (see AGENTS.md), no API
# key is needed — set FINX_LLM_PROVIDER=ollama and FINX_VLM_PROVIDER=ollama.
